// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// USER MODEL
// =========================
model User {
  userId    Int    @id @default(autoincrement())
  firstName String
  lastName  String
  email     String @unique
  password  String
  role      Role   @default(PLAYER)

  dateOfBirth   DateTime?
  gender        String?
  Phone         String?
  location      String?
  profilePhoto  String?
  // position      String?
  preferredFoot preferredFoot?
  // matchesPlayed Int?
  // goalsScored   Int?
  // assist        Int?
  tournaments   Tournament[]   @relation("TournamentCreator")
  clubs         Club[]         @relation("ClubCreator")
  requests      Request[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userClubs     UserClub[]
  matchEvents   MatchEvent[]
  assists       MatchEvent[]   @relation("AssistPlayer")
  matchLineups  MatchLineup[]

  @@map("users")
}

enum Role {
  PLAYER
  SUPERADMIN
}

enum preferredFoot {
  LEFT
  RIGHT
  BOTH
}

// =========================
// CLUB MODEL
// =========================
model Club {
  clubId       Int           @id @default(autoincrement())
  name         String
  description  String
  logo         String?
  location     String
  foundedDate  DateTime
  createdBy    Int
  creator      User          @relation("ClubCreator", fields: [createdBy], references: [userId])
  requests     Request[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userClubs    UserClub[]
  schedulesAsTeamOne Schedule[] @relation("TeamOne")
  schedulesAsTeamTwo Schedule[] @relation("TeamTwo")
  matchEvents  MatchEvent[]
  matchLineups MatchLineup[]
}

model Request {
  requestId     Int           @id @default(autoincrement())
  userId        Int
  clubId        Int
  message       String?
  status        RequestStatus @default(PENDING)
  dateRequested DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [userId])
  club          Club          @relation(fields: [clubId], references: [clubId])

  @@unique([userId, clubId])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// =========================
// USERCLUB MODEL
// =========================
model UserClub {
  userClubId Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [userId])
  userId Int

  club   Club @relation(fields: [clubId], references: [clubId])
  clubId Int

  position String?
  JoinedAt DateTime @default(now())

  @@unique([userId, clubId])
}

// =========================
// TOURNAMENT MODEL
// =========================
model Tournament {
  tournamentId Int      @id @default(autoincrement())
  name         String
  description  String
  logo         String?
  location     String
  entryFee     Decimal  @db.Decimal(10, 2)
  startDate    DateTime
  endDate      DateTime
  format       Format
  createdBy    Int
  creator      User     @relation("TournamentCreator", fields: [createdBy], references: [userId])
  status       Status
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Status {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum Format {
  KNOCKOUT
  LEAGUE
}

// =========================
// SCHEDULE MODEL
// =========================
model Schedule {
  scheduleId     Int            @id @default(autoincrement())
  scheduleStatus ScheduleStatus
  scheduleType   String
  location       String
  date           DateTime
  // teamOne Club @relation(fields:[teamOneId],references[clubId])
  // teamOneId Int 
  teamOne        Club           @relation("TeamOne", fields: [teamOneId], references: [clubId])
  teamOneId      Int
  teamTwo        Club           @relation("TeamTwo", fields: [teamTwoId], references: [clubId])
  teamTwoId      Int

  match Match?
}

enum ScheduleStatus {
  UPCOMING
  FINISHED
  ONGOING
  CANCELLED
}

model Match {
  matchId    Int      @id @default(autoincrement())
  schedule   Schedule @relation(fields: [scheduleId], references: [scheduleId])
  scheduleId Int      @unique

  teamOneGoals Int
  teamTwoGoals Int

  playedAt DateTime

  events  MatchEvent[]
  lineups MatchLineup[]
}

model MatchEvent {
  matchEventId Int   @id @default(autoincrement())
  match        Match @relation(fields: [matchId], references: [matchId])
  matchId      Int

  user   User @relation(fields: [userId], references: [userId])
  userId Int

  assistBy   User? @relation("AssistPlayer", fields: [assistById], references: [userId])
  assistById Int?

  club   Club @relation(fields: [clubId], references: [clubId])
  clubId Int

  eventType MatchEventType
  minute    Int
}

enum MatchEventType {
  GOAL
  ASSIST
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
}

model MatchLineup {
  id      Int   @id @default(autoincrement())
  match   Match @relation(fields: [matchId], references: [matchId])
  matchId Int

  user   User @relation(fields: [userId], references: [userId])
  userId Int

  club   Club @relation(fields: [clubId], references: [clubId])
  clubId Int

  isStarter     Boolean
  minutesPlayed Int
}
