// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User{
  userId        Int           @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String        @unique
  password      String
  role          Role          @default(PLAYER)

  dateOfBirth   DateTime?
  gender        String?
  Phone         String?
  location      String?
  profilePhoto  String?
  position      String?
  preferredFoot preferredFoot?
  matchesPlayed Int?
  goalsScored   Int?
  assist        Int?
  tournaments   Tournament[]  @relation("TournamentCreator")
  clubs         Club[]        @relation("ClubCreator")
  requests      Request[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("users")
}

enum Role{
  PLAYER
  SUPERADMIN
}

enum preferredFoot{
  LEFT
  RIGHT
  BOTH
}
model Tournament{
  tournamentId  Int         @id @default(autoincrement())
  name          String
  description   String
  logo          String?
  location      String
  entryFee      Decimal     @db.Decimal(10,2)
  startDate     DateTime
  endDate       DateTime
  format        Format
  createdBy     Int
  creator       User        @relation("TournamentCreator", fields:[createdBy], references:[userId])
  status        Status
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}


enum Status{
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum Format{
  KNOCKOUT
  LEAGUE
}

model Club{
  clubId        Int         @id @default(autoincrement())
  name          String
  description   String
  logo          String?
  location      String
  foundedDate   DateTime
  createdBy     Int
  creator       User        @relation("ClubCreator", fields:[createdBy], references:[userId])
  requests      Request[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

}

model Request{
  requestId        Int         @id @default(autoincrement())
  userId           Int          
  clubId           Int
  status           RequestStatus  @default(PENDING)
  dateRequested    DateTime    @default(now())
  user             User        @relation(fields: [userId], references: [userId])
  club             Club        @relation(fields: [clubId], references: [clubId])

  @@unique([userId, clubId])
}

enum RequestStatus{
  PENDING
  APPROVED
  REJECTED
}