// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Optional: for migrations
}

// =========================
// USER MODEL
// =========================
model User {
  userId    Int    @id @default(autoincrement())
  firstName String
  lastName  String
  email     String @unique
  password  String?
  role      Role   @default(PLAYER)
  authProvider AuthProvider @default(LOCAL)
  googleId String? @unique
  emailVerified Boolean @default(false)
  emailVerificationCode String?
  emailVerificationExpiresAt DateTime?

  dateOfBirth   DateTime?
  gender        String?
  Phone         String?
  location      String?
  locationLatitude  Float?
  locationLongitude Float?
  locationPlaceId   String?
  profilePhoto  String?
  preferredFoot preferredFoot?

  // Relations
  tournaments      Tournament[]   @relation("TournamentCreator")
  clubs            Club[]         @relation("ClubCreator")
  clubRequests     ClubRequest[]
  userClubs        UserClub[]
  matchEvents      MatchEvent[]
  assists          MatchEvent[]   @relation("AssistPlayer")
  matchLineups     MatchLineup[]
  createdSchedules Schedule[]     @relation("CreatedByUser")
  messages    Message[]
  notifications Notification[]
  payments      Payment[]       


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Notification {
  notificationId Int              @id @default(autoincrement())
  userId         Int
  type           NotificationType
  title          String
  message        String
  link           String?
  data           Json?
  isRead         Boolean          @default(false)
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

enum NotificationType {
  CLUB_JOIN_REQUEST
  CLUB_JOIN_APPROVED
  CLUB_JOIN_REJECTED
  SCHEDULE_CREATED
  TOURNAMENT_JOIN_REQUEST
  TOURNAMENT_JOIN_APPROVED
  TOURNAMENT_JOIN_REJECTED
  LINEUP_ADDED
  MATCH_EVENT_ADDED
  SYSTEM
}

enum Role {
  PLAYER
  SUPERADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum preferredFoot {
  LEFT
  RIGHT
  BOTH
}

// =========================
// CLUB MODEL
// =========================
model Club {
  clubId      Int      @id @default(autoincrement())
  name        String   @unique
  description String
  logo        String?
  location    String
  locationLatitude  Float?
  locationLongitude Float?
  locationPlaceId   String?
  foundedDate DateTime
  createdBy   Int

  // Relations
  creator                User                     @relation("ClubCreator", fields: [createdBy], references: [userId])
  clubRequests           ClubRequest[]
  userClubs              UserClub[]
  schedulesAsTeamOne     Schedule[]               @relation("TeamOne")
  schedulesAsTeamTwo     Schedule[]               @relation("TeamTwo")
  createdSchedules       Schedule[]               @relation("CreatedFromClub")
  matchEvents            MatchEvent[]
  matchLineups           MatchLineup[]
  tournamentRegistrations TournamentRegistration[]
  tournamentsWon         Tournament[]             @relation("TournamentWinner")
  tournamentsRunnerUp    Tournament[]             @relation("TournamentRunnerUp")
  messages    Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clubs")
}

// =========================
// CLUB REQUEST MODEL (Renamed from Request for clarity)
// =========================
model ClubRequest {
  requestId         Int           @id @default(autoincrement())
  userId            Int
  clubId            Int
  preferredPosition String
  whyJoin           String?
  additionalMessage String?
  status            RequestStatus @default(PENDING)
  dateRequested     DateTime      @default(now())
  reviewedAt        DateTime?
  reviewedBy        Int?

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [clubId], onDelete: Cascade)

  @@unique([userId, clubId])
  @@map("club_requests")
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// =========================
// USERCLUB MODEL (Approved club members)
// =========================
model UserClub {
  userClubId Int @id @default(autoincrement())

  userId Int
  clubId Int

  role     ClubRole @default(MEMBER)
  position String?
  joinedAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [clubId], onDelete: Cascade)

  @@unique([userId, clubId])
  @@map("user_clubs")
}

enum ClubRole {
  ADMIN
  MEMBER
}

// =========================
// TOURNAMENT MODEL
// =========================
model Tournament {
  tournamentId Int     @id @default(autoincrement())
  name         String
  description  String
  logo         String?
  location     String
  locationLatitude  Float?
  locationLongitude Float?
  locationPlaceId   String?
  entryFee     Decimal @db.Decimal(10, 2)
  startDate    DateTime
  endDate      DateTime
  format       Format
  createdBy    Int
  status       Status                 @default(UPCOMING)
  winnerClubId Int?
  runnerUpClubId Int?
  paymentInstructions String?
  enrollmentStatus EnrollmentStatus @default(OPEN)

  // Relations
  creator        User                     @relation("TournamentCreator", fields: [createdBy], references: [userId])
  schedules      Schedule[]               @relation("CreatedFromTournament")
  registrations  TournamentRegistration[]
  admins         TournamentAdmin[]
  winnerClub     Club?                    @relation("TournamentWinner", fields: [winnerClubId], references: [clubId])
  runnerUpClub   Club?                    @relation("TournamentRunnerUp", fields: [runnerUpClubId], references: [clubId])
  payments    Payment[]


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tournaments")
}

enum Status {
  UPCOMING
  ONGOING
  FINISHED
  CANCELLED
}

enum EnrollmentStatus {
  OPEN
  CLOSED
}

enum Format {
  KNOCKOUT
  LEAGUE
}

// =========================
// TOURNAMENT ADMIN MODEL
// =========================
model TournamentAdmin {
  id           Int @id @default(autoincrement())
  tournamentId Int
  userId       Int
  assignedAt   DateTime @default(now())

  // Relations
  tournament Tournament @relation(fields: [tournamentId], references: [tournamentId], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@map("tournament_admins")
}

// =========================
// TOURNAMENT REGISTRATION MODEL
// =========================
model TournamentRegistration {
  registrationId Int                    @id @default(autoincrement())
  tournamentId   Int
  clubId         Int
  registeredBy   Int
  status         RegistrationStatus     @default(PENDING)
  paymentStatus  PaymentStatus          @default(PENDING)
  paymentReference String?
  paymentAmount  Decimal?               @db.Decimal(10, 2)
  registeredAt   DateTime               @default(now())
  reviewedAt     DateTime?
  reviewedBy     Int?
  notes          String?

  // Relations
  tournament Tournament @relation(fields: [tournamentId], references: [tournamentId], onDelete: Cascade)
  club       Club       @relation(fields: [clubId], references: [clubId], onDelete: Cascade)

  @@unique([tournamentId, clubId])
  @@map("tournament_registrations")
}

enum RegistrationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  WAIVED
}

// =========================
// SCHEDULE MODEL
// =========================
model Schedule {
  scheduleId     Int            @id @default(autoincrement())
  scheduleStatus ScheduleStatus @default(UPCOMING)
  scheduleType   String
  location       String
  date           DateTime
  matchSize      Int            @default(11)

  // Team references
  teamOneId Int
  teamTwoId Int

  // Optional: Created from Club or Tournament
  createdFromClub       Int?
  createdFromTournament Int?
  createdFromUser       Int

  // Relations
  teamOne               Club        @relation("TeamOne", fields: [teamOneId], references: [clubId])
  teamTwo               Club        @relation("TeamTwo", fields: [teamTwoId], references: [clubId])
  creatorFromClub       Club?       @relation("CreatedFromClub", fields: [createdFromClub], references: [clubId])
  creatorFromTournament Tournament? @relation("CreatedFromTournament", fields: [createdFromTournament], references: [tournamentId])
  creationFromUser      User        @relation("CreatedByUser", fields: [createdFromUser], references: [userId])
  match                 Match?

  scheduleRequests      ScheduleRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schedules")
}

enum ScheduleStatus {
  PENDING
  UPCOMING
  ONGOING
  FINISHED
  CANCELLED
}

// =========================
// SCHEDULE REQUEST MODEL
// =========================
model ScheduleRequest {
  requestId    Int                   @id @default(autoincrement())
  scheduleId   Int
  teamTwoId    Int
  status       ScheduleRequestStatus @default(PENDING)
  requestedAt  DateTime              @default(now())
  reviewedAt   DateTime?

  // Relations
  schedule Schedule @relation(fields: [scheduleId], references: [scheduleId], onDelete: Cascade)

  @@map("schedule_requests")
}

enum ScheduleRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// =========================
// MATCH MODEL
// =========================
model Match {
  matchId    Int      @id @default(autoincrement())
  scheduleId Int      @unique

  teamOneGoals Int @default(0)
  teamTwoGoals Int @default(0)

  playedAt  DateTime
  startedAt DateTime?
  endedAt   DateTime?

  // Relations
  schedule Schedule      @relation(fields: [scheduleId], references: [scheduleId], onDelete: Cascade)
  matchEvents   MatchEvent[]
  lineups  MatchLineup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("matches")
}

// =========================
// MATCH EVENT MODEL
// =========================
model MatchEvent {
  matchEventId Int   @id @default(autoincrement())
  matchId      Int
  userId       Int
  assistById   Int?
  clubId       Int

  eventType MatchEventType
  minute    Int

  // Relations
  match    Match @relation(fields: [matchId], references: [matchId], onDelete: Cascade)
  user     User  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  assistBy User? @relation("AssistPlayer", fields: [assistById], references: [userId])
  club     Club  @relation(fields: [clubId], references: [clubId], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("match_events")
}

enum MatchEventType {
  GOAL
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
}

// =========================
// MATCH LINEUP MODEL
// =========================
model MatchLineup {
  id      Int @id @default(autoincrement())
  matchId Int
  userId  Int
  clubId  Int

  isStarter     Boolean
  position      String?
  minutesPlayed Int     @default(0)

  // Relations
  match Match @relation(fields: [matchId], references: [matchId], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  club  Club  @relation(fields: [clubId], references: [clubId], onDelete: Cascade)

  @@unique([matchId, userId])
  @@map("match_lineups")
}

// =========================
// MESSAGE MODEL
// =========================
model Message{
  messageId   Int          @id @default(autoincrement())
  clubId      Int
  userId      Int
  content     String
  messageType MessageType  @default(TEXT) 
  attachment  String?

  //Relations
  club        Club     @relation(fields: [clubId], references: [clubId], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@index([userId])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}


// =========================
// PAYMENT MODEL
// =========================
model Payment {
  paymentId          Int            @id @default(autoincrement())
 // Customer Details
  customerName  String
  customerEmail String
  customerPhone String
  
  // Product Details
  productName   String
  productId     String
  amount        Decimal  @db.Decimal(10, 2)
  
  // Payment Gateway
  paymentGateway PaymentGatewayType
  
  // Status
  status        TransactionStatus @default(PENDING)
  
  // Relations (Optional - link to existing models)
  userId        Int?
  user          User?    @relation(fields: [userId], references: [userId], onDelete: SetNull)
  
  tournamentId  Int?
  tournament    Tournament? @relation(fields: [tournamentId], references: [tournamentId], onDelete: SetNull)
  
  // Gateway Response Data
  gatewayTransactionId String? @unique
  gatewayResponse      Json?   // Store raw gateway response
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([customerEmail])
  @@index([productId])
  @@index([gatewayTransactionId])
  @@map("payments")
}

enum PaymentGatewayType {
  ESEWA
  KHALTI
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}